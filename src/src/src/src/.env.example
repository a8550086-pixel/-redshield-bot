# ---- RedShield credentials (required) ----
REDSHIELD_URL=https://app.getredshield.com
EVENTS_PATH=/events
REDSHIELD_EMAIL=you@example.com
REDSHIELD_PASSWORD=change-me

# ---- n8n webhook (required) ----
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/redshield

# ---- Polling ----
POLL_INTERVAL_MS=5000
MAX_SEEN_IDS=5000

# ---- Selectors: MUST be adjusted to match the real RedShield DOM ----
# See README "Finding selectors" for how to inspect these with DevTools.
SEL_LOGIN_EMAIL=input[type="email"], input[name="email"]
SEL_LOGIN_PASSWORD=input[type="password"], input[name="password"]
SEL_LOGIN_SUBMIT=button[type="submit"]
SEL_LOGGED_IN_MARKER=nav, [data-testid="app-shell"], header
SEL_EVENT_ITEM=[data-testid="event-row"], table tbody tr, .event-item, li.event
SEL_EVENT_ID_ATTR=data-id
SEL_EVENT_LINK=a
SEL_EVENT_DETAIL=main, [data-testid="event-detail"], .event-detail, body

# ---- Storage ----
# On Render, point this at your mounted persistent disk (see render.yaml).
DATA_DIR=./data
SESSION_FILE=session.json
SEEN_EVENTS_FILE=seen-events.json

# ---- Browser ----
HEADLESS=true
NAVIGATION_TIMEOUT_MS=30000

# ---- Health server ----
PORT=10000
